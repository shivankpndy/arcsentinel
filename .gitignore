# ─────────────────────────────────────────────
#  ARC SENTINEL — .gitignore
# ─────────────────────────────────────────────

# ── Node / Next.js (ground-station/) ─────────
node_modules/
.next/
out/
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Python (ground tools) ────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
.Python
env/
venv/
.venv/
pip-log.txt
pip-delete-this-directory.txt
dist/
build/
*.egg-info/
.eggs/

# ── Arduino / Firmware build artifacts ───────
# Compiled binaries — never commit these, always rebuild
firmware/**/*.bin
firmware/**/*.elf
firmware/**/*.hex
firmware/**/*.map
firmware/**/*.d
build/
*.build/

# Arduino IDE generated folders
firmware/**/build/
firmware/**/.arduino*/

# ── OTA artifacts ─────────────────────────────
# Compiled firmware bins produced by arc_uplink.py / arduino-cli
tools/*.bin
tools/build/
*.ota.bin

# ── Logs & Telemetry recordings ──────────────
*.log
logs/
telemetry/
recordings/
captures/

# ── Camera captures ───────────────────────────
# Images downloaded from the satellite
*.jpg
*.jpeg
*.png
!logo.png
!ground-station/public/logo.png

# ── OS cruft ─────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.fuse_hidden*
.directory
.Trash-*

# ── Editor / IDE ──────────────────────────────
.vscode/
!.vscode/extensions.json
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace
.project
.classpath
.settings/
*.code-workspace

# ── Secrets — never commit these ─────────────
secrets.h
config_local.h
credentials.h
*.key
*.pem
*.cert

# ── Misc ──────────────────────────────────────
.cache/
.temp/
tmp/